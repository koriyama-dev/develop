# ==============================================================================
# Docker Infrastructure Settings
# ==============================================================================

# --- Project Configuration ---
# コンテナ名の接頭辞
COMPOSE_PROJECT_NAME=sandbox1
TZ=Asia/Tokyo
APP_TIMEZONE=Asia/Tokyo

# --- Web Server (Apache) ---
APP_PORT=80
APP_SSL_PORT=443

# --- Database (MySQL 8.4 LTS) ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=base
DB_USERNAME=root
DB_PASSWORD=passwd
DB_ROOT_PASSWORD=passwd

# --- Mail (MailHog) ---
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_DASHBOARD_PORT=8025

# --- PHP / Debug ---
# XDEBUG_MODE: debug(有効) / off(無効)
XDEBUG_MODE=debug
# Windows/Mac の Docker Desktop 環境でホストPCを指し示す
XDEBUG_CLIENT_HOST=host.docker.internal

# ==============================================================================
# Laravel Application Settings (Reference)
# ==============================================================================
# ※ 以下の値は src/.env（アプリ側）の設定と「同期」させる必要がある

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://base.local
