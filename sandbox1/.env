#==============================================================================
# Docker Infrastructure Settings
#==============================================================================

# ----- タイムゾーン設定 -----
TZ=Asia/Tokyo
APP_TIMEZONE=Asia/Tokyo

# ----- プロジェクト設定 -----
COMPOSE_PROJECT_NAME=sandbox1

# ----- Webサーバー (Apache) -----
APP_PORT=80
APP_SSL_PORT=443

# ----- データベース (MySQL 8.4 LTS) -----
# MySQL 8.4 は 2026年4月時点の現行 LTS (8.0 は同月 EOL 到達済み)
DB_PORT=3306
DB_DATABASE=base
DB_ROOT_PASSWORD=passwd

# ----- キャッシュ (Redis 7.2) -----
REDIS_PORT=6379

# ----- メール (Mailpit) -----
MAIL_PORT=1025
MAIL_DASHBOARD_PORT=8025

# ----- PHP / デバッグ -----
# XDEBUG_MODE: debug(有効) / off(無効)
# [本番環境] off を設定すること
XDEBUG_MODE=debug
XDEBUG_CLIENT_PORT=9003
