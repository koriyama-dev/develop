# ==============================================================================
# Docker Infrastructure Settings
# ==============================================================================

TZ=Asia/Tokyo
APP_TIMEZONE=Asia/Tokyo

# --- Project Configuration ---
# コンテナ名の接頭辞
COMPOSE_PROJECT_NAME=sandbox1

# --- Web Server (Apache) ---
APP_PORT=80
APP_SSL_PORT=443

# --- Database (MySQL) ---
DB_PORT=3306
DB_DATABASE=base
DB_ROOT_PASSWORD=passwd

# --- redis ---
REDIS_PORT=6379

# --- Mail (mailpit) ---
MAIL_PORT=1025
MAIL_DASHBOARD_PORT=8025

# --- PHP / Debug ---
# XDEBUG_MODE: debug(有効) / off(無効)
XDEBUG_MODE=debug
XDEBUG_CLIENT_PORT=9003
