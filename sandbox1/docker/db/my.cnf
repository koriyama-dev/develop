#==============================================================================
# MySQL 8.4 LTS 設定
#==============================================================================
[mysqld]

# ----- メモリ最適化 (WSL2 16GB ホスト環境向け) -----
# InnoDB のバッファプールを RAM の約 12.5% に設定 (専有サーバーでない環境向けの保守値)
innodb_buffer_pool_size = 1G
join_buffer_size = 2M
sort_buffer_size = 2M
read_rnd_buffer_size = 2M

# ----- 接続・パフォーマンス設定 -----
# Docker コンテナ内ではホスト名解決が不要なため DNS ルックアップを無効化
host-cache-size=0
skip-name-resolve
# デフォルト 151 をコンテナ用途として適正値のまま明示
max_connections=151

# ----- バイナリログ設定 -----
# log_bin=mysql-bin
# binlog_format=ROW
# 7日=604800秒
# binlog_expire_logs_seconds=604800

# ----- スロークエリログ -----
# N+1 問題やフルテーブルスキャンを早期発見するために有効化
slow_query_log=1
slow_query_log_file=/var/lib/mysql/slow.log
long_query_time=1

# ----- 文字コード設定 -----
# Laravel の Unicode 完全対応のため utf8mb4 を指定 (絵文字等の 4 バイト文字も格納可能)
character-set-server=utf8mb4
# utf8mb4_0900_ai_ci は MySQL 8.x のデフォルト照合順序 (大文字小文字・アクセント無視)
collation-server=utf8mb4_0900_ai_ci

# ----- MySQL 8.4 LTS 認証設定 -----
# MySQL 8.4 でデフォルト認証方式となった caching_sha2_password を明示
authentication_policy=caching_sha2_password

# ----- WSL2 / Docker 固有設定 -----
# Windows ファイルシステムは Linux の libaio (非同期 I/O) をサポートしないため OFF
innodb_use_native_aio=0

# ----- クライアント設定 -----
[client]
# サーバー側と文字コードを統一してクライアント接続時の文字化けを防ぐ
default-character-set=utf8mb4
