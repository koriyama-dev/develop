#==============================================================================
# MySQL サーバー設定
#==============================================================================
[mysqld]

# ----- 文字コード設定 (Laravel 13 完全対応) -----
# 文字コードをutf8mb4に固定 (Laravelでの多言語対応と絵文字利用を保証するため)
character-set-server=utf8mb4
# 照合順序を指定 (MySQL 8.4標準の比較規則で一貫性を保つため)
collation-server=utf8mb4_0900_ai_ci

# ----- 認証・セキュリティ設定 -----
# 認証方式を明示 (MySQL 8.4のデフォルト値を固定し将来の変更から保護するため)
authentication_policy=caching_sha2_password

# ----- 接続・パフォーマンス設定 -----
# ホストキャッシュを無効化 (コンテナ再起動時の接続トラブルを防止するため)
host-cache-size=0
# 名前解決を無効化 (ネットワーク経由の接続オーバーヘッドを削減するため)
skip-name-resolve
# 最大接続数を明示 (デフォルト151のままコンテナ用途として適正値を示すため)
max_connections=151

# ----- メモリ最適化 (WSL2 8GB環境向け) -----
# InnoDBキャッシュを確保 (利用可能メモリの約12%を割り当て効率的に動作させるため)
innodb_buffer_pool_size=1G
# 結合用バッファを制限 (コネクション増大時のメモリ枯渇を防ぐため)
join_buffer_size=2M
# ソート用メモリを確保 (ファイルソートの発生を抑えクエリを高速化するため)
sort_buffer_size=2M
# ランダム読込バッファを設定 (ソート後のデータ抽出を効率化するため)
read_rnd_buffer_size=2M

# ----- スロークエリログ (開発環境のクエリ最適化用) -----
# スロークエリログを有効化 (パフォーマンスボトルネックの発見を容易にするため)
slow_query_log=1
slow_query_log_file=/var/lib/mysql/slow.log
# 1秒超のクエリを対象 (意図せず重くなったクエリを検知するため)
long_query_time=1

# ----- WSL2 / Docker 固有の設定 -----
# ネイティブAIOを無効化 (WindowsファイルシステムとのAIO互換性問題を回避するため)
innodb_use_native_aio=0

#==============================================================================
# クライアント設定
#==============================================================================
[client]
# クライアント文字コードを指定 (通信時のエンコーディング不一致を防止するため)
default-character-set=utf8mb4
