#==============================================================================
# MySQL サーバー設定
#==============================================================================
[mysqld]

# ----- 文字コード設定 -----
# Laravel での多言語対応と絵文字利用を保証するため utf8mb4 に固定
character-set-server=utf8mb4
# MySQL 8.4 標準の照合順序で文字比較の一貫性を保持
collation-server=utf8mb4_0900_ai_ci

# ----- 認証・セキュリティ設定 -----
# MySQL 8.4 のデフォルト認証方式を明示固定し将来の変更から保護
# (mysql_native_password は MySQL 8.4 でデフォルト無効化済みのため設定不要)
authentication_policy=caching_sha2_password

# ----- 接続・パフォーマンス設定 -----
# コンテナ再起動時の接続トラブルを防止するためホストキャッシュを無効化
host-cache-size=0
# ネットワーク経由の接続オーバーヘッドを削減するため名前解決を無効化
skip-name-resolve
# デフォルト 151 をコンテナ用途として適正値のまま明示
max_connections=151

# ----- メモリ最適化 (WSL2 8GB環境向け) -----
# 利用可能メモリの約 12% を割り当て InnoDB キャッシュを効率的に動作させる
innodb_buffer_pool_size=1G
# コネクション増大時のメモリ枯渇を防ぐため結合用バッファを制限
join_buffer_size=2M
# ファイルソートの発生を抑えクエリを高速化するためソート用メモリを確保
sort_buffer_size=2M
# ソート後のデータ抽出を効率化するためランダム読込バッファを設定
read_rnd_buffer_size=2M

# ----- スロークエリログ (パフォーマンスボトルネック検知用) -----
slow_query_log=1
slow_query_log_file=/var/lib/mysql/slow.log
# 1 秒超のクエリを対象にして意図せず重くなったクエリを検知
long_query_time=1

# ----- WSL2 / Docker 固有の設定 -----
# Windows ファイルシステムとの AIO 互換性問題を回避するためネイティブ AIO を無効化
innodb_use_native_aio=0

#==============================================================================
# クライアント設定
#==============================================================================
[client]
# 通信時のエンコーディング不一致を防止するためクライアント文字コードを指定
default-character-set=utf8mb4
