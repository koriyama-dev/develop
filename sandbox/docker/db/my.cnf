[mysqld]
# --- メモリ最適化 (WSL2 8GB環境向け) ---
innodb_buffer_pool_size = 1G
join_buffer_size = 2M
sort_buffer_size = 2M
read_rnd_buffer_size = 2M

# --- 接続・パフォーマンス設定 ---
host-cache-size=0
skip-name-resolve

# --- 文字コード設定 (Laravel 13 完全対応) ---
character-set-server=utf8mb4
collation-server=utf8mb4_0900_ai_ci

# --- MySQL 8.4 LTS 最適化 ---
# 8.4では authentication_policy が推奨
authentication_policy=caching_sha2_password

# --- WSL2 / Docker 固有の修正 ---
# Windowsファイルシステム(WSL2)上でのI/Oエラーを回避するために必須
innodb_use_native_aio=0

[client]
# クライアント側も utf8mb4 を指定
default-character-set=utf8mb4
