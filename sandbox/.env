# ==============================================================================
# Docker Infrastructure Settings
# ==============================================================================

# --- Project Configuration ---
# コンテナ名の接頭辞。他のプロジェクトと混ざらないように命名。
COMPOSE_PROJECT_NAME=sandbox
TZ=Asia/Tokyo

# --- Web Server (Apache) ---
# ホスト側（ブラウザ）からアクセスするポート。
# 80/443が他で使われている場合はここを変えるだけでOK。
APP_PORT=80
APP_SSL_PORT=443

# --- Database (MySQL 8.4 LTS) ---
# docker-compose.yml 内の ${DB_...} 変数に注入される。
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=base
DB_USERNAME=root
DB_PASSWORD=passwd
DB_ROOT_PASSWORD=passwd

# --- Mail (MailHog) ---
# SMTP受信用ポート(1025)と、ブラウザ確認用画面のポート(8025)。
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_DASHBOARD_PORT=8025

# --- PHP / Debug ---
# XDEBUG_MODE: debug(有効) / off(無効)。
# 開発が一段落したら off にすると動作がさらに軽くなります。
XDEBUG_MODE=debug
# Windows/Mac の Docker Desktop 環境でホストPCを指し示す。
XDEBUG_CLIENT_HOST=host.docker.internal

# ==============================================================================
# Laravel Application Settings (Reference)
# ==============================================================================
# ※ 以下の値は src/base/.env（アプリ側）の設定と「同期」させる必要があります。

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# 000-default.conf の ServerName と一致させることで SSL 証明書エラーを防ぎます。
APP_URL=https://base.local
