#==============================================================================
# Docker インフラ共通設定
#==============================================================================

# ----- タイムゾーン -----
TZ=Asia/Tokyo
APP_TIMEZONE=Asia/Tokyo

# ----- プロジェクト設定 -----
COMPOSE_PROJECT_NAME=sandbox2

# ----- Web サーバー (Nginx) -----
APP_PORT=80
APP_SSL_PORT=443

# ----- データベース (MySQL 8.4 LTS) -----
DB_PORT=3306
DB_DATABASE=base
# [本番環境] 十分な強度のパスワードに変更し、Secrets管理ツールで管理すること
DB_ROOT_PASSWORD=passwd

# ----- キャッシュ (Redis 8) -----
REDIS_PORT=6379

# ----- メールテスト (Mailpit) -----
MAIL_PORT=1025
MAIL_DASHBOARD_PORT=8025

# ----- PHP / デバッグ (Xdebug) -----
# [本番環境] XDEBUG_MODE=off に変更すること
# debug=有効 / off=無効
XDEBUG_MODE=debug
XDEBUG_CLIENT_PORT=9003
