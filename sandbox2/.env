#==============================================================================
# Docker Infrastructure Settings
#==============================================================================

# ----- タイムゾーン設定 -----
TZ=Asia/Tokyo
APP_TIMEZONE=Asia/Tokyo

# ----- プロジェクト設定 -----
COMPOSE_PROJECT_NAME=sandbox2

# ----- Webサーバー (nginx) -----
APP_PORT=80
APP_SSL_PORT=443

# ----- データベース (MySQL 8.4 LTS) -----
DB_PORT=3306
DB_DATABASE=base
DB_ROOT_PASSWORD=passwd

# ----- キャッシュ (Valkey 8 / Redis) -----
REDIS_PORT=6379

# ----- メール (Mailpit) -----
MAIL_PORT=1025
MAIL_DASHBOARD_PORT=8025

# ----- PHP / デバッグ -----
# XDEBUG_MODE: debug(有効) / off(無効)
XDEBUG_MODE=debug
XDEBUG_CLIENT_PORT=9003
