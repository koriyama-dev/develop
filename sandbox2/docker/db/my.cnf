#==============================================================================
# MySQL 8.4 LTS 設定
#==============================================================================

[mysqld]

# ----- メモリ最適化 (WSL2 8GB環境向け) -----
# InnoDBのバッファプールをRAMの約12.5%に設定(専有サーバーでない環境向けの保守値)
innodb_buffer_pool_size = 1G
join_buffer_size = 2M
sort_buffer_size = 2M
read_rnd_buffer_size = 2M

# ----- 接続・パフォーマンス設定 -----
# Dockerコンテナ内ではホスト名解決が不要なためDNSルックアップを無効化
host-cache-size=0
skip-name-resolve
# Laravelのキューワーカー+FPMの並列接続数に対応するためデフォルト151から拡大
max_connections=200

# ----- スロークエリログ -----
# N+1問題やフルテーブルスキャンを早期発見するために有効化
# [本番環境] long_query_timeを用途に応じて調整(本番では0.5〜1秒が一般的)
slow_query_log=1
slow_query_log_file=/var/lib/mysql/slow.log
long_query_time=1

# ----- 文字コード設定 -----
# LaravelのUnicode完全対応のためutf8mb4を指定(絵文字等の4バイト文字も格納可能)
character-set-server=utf8mb4
# utf8mb4_0900_ai_ciはMySQL 8.xのデフォルト照合順序(大文字小文字・アクセント無視)
collation-server=utf8mb4_0900_ai_ci

# ----- MySQL 8.4 LTS 認証設定 -----
# MySQL 8.4でデフォルト認証方式となったcaching_sha2_passwordを明示
# (mysql_native_passwordはMySQL 9.0で削除済み)
authentication_policy=caching_sha2_password

# ----- WSL2 / Docker 固有設定 -----
# WindowsファイルシステムはLinuxのlibaio(非同期I/O)をサポートしないためOFF
# [本番環境] Linuxネイティブ環境ではこの行を削除するか1に変更すること
innodb_use_native_aio=0

# ----- クライアント設定 -----
[client]
# サーバー側と文字コードを統一してクライアント接続時の文字化けを防ぐ
default-character-set=utf8mb4
